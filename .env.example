# ===== PATHS =====
# File containing proxy list (one per line, format: protocol://host:port)
PROXY_FILE=data/proxies.txt
# SQLite database URL for account/task/worker storage
DATABASE_URL=sqlite:///./data/reddit.db
# Directory for Camofox session data
SESSION_DIR=data/sessions
# Directory for application logs
LOG_DIR=data/logs
# JSON file with browser profiles for Camofox
PROFILES_PATH=profiles.json

# ===== CAMOFOX =====
# Port where Camofox browser listens for HTTP requests
CAMOFOX_PORT=9377
# Path to Camofox installation (relative to project root or absolute)
CAMOFOX_DIR=../camofox

# ===== PROXY =====
# Proxy mode: sticky (same proxy per session) or dynamic (rotate)
PROXY_MODE=sticky
# Whether to inject proxy into sessions by default
USE_PROXIES_BY_DEFAULT=true

# ===== VNC =====
# Enable VNC server for browser debugging
VNC_ENABLED=false
# VNC server port
VNC_PORT=5999

# ===== SESSION =====
# Maximum age before session is considered stale (hours)
MAX_SESSION_AGE_HOURS=72

# ===== ACTION TIMING =====
# Minimum delay between actions (milliseconds)
ACTION_DELAY_MS_MIN=1000
# Maximum delay between actions (milliseconds)
ACTION_DELAY_MS_MAX=3000
# Default number of workers per task
BATCH_SIZE_DEFAULT=50

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== CAPTCHA =====
# API keys for captcha solving services (leave commented if not used)
# CAPSOLVER_API_KEY=your_key_here
# TWOCAPTCHA_API_KEY=your_key_here

# ===== MODE =====
# Application mode: production or test
APP_MODE=production

# ===== TEST MODE =====
# Test server URL (mock Reddit endpoints for testing)
TEST_SERVER_URL=http://localhost:8080
TEST_SERVER_PORT=8080
TEST_DB_URL=sqlite:///./data/test.db
TEST_SESSION_DIR=data/test_sessions
# Proxy: uses PROXY_FILE (same as production, 1:1 allocation)

# ===== TUNNEL =====
# Cloudflare tunnel configuration for exposing the app
TUNNEL_DOMAIN=vaproh.space
TUNNEL_SUBDOMAIN=reorchestra-test
TUNNEL_NAME=reorchestra-test
TUNNEL_PORT=8080
