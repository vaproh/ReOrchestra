# ===== PATHS =====
DATABASE_URL=sqlite:///./data/reddit.db
LOG_DIR=data/logs

# ===== CAMOFOX =====
CAMOFOX_PORT=9377
CAMOFOX_DIR=../camofox

# ===== PROXY =====
PROXY_MODE=sticky
USE_PROXIES_BY_DEFAULT=true

# ===== VNC =====
VNC_ENABLED=false
VNC_PORT=5999

# ===== ACTION TIMING =====
ACTION_DELAY_MS_MIN=1000
ACTION_DELAY_MS_MAX=3000
BATCH_SIZE_DEFAULT=50

# ===== LOGGING =====
LOG_LEVEL=INFO

# ===== CORS =====
CORS_ALLOWED_ORIGINS=*
